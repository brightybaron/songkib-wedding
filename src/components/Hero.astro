---
import { Image } from "astro:assets";
import bgHero from "@assets/foto/duo-3.jpeg";
---

<section class="relative h-dvh w-full overflow-hidden">
  <div class="absolute inset-0 w-full h-screen">
    <Image
      loading={"eager"}
      src={bgHero}
      alt="hero background"
      class="h-full w-full object-cover object-center"
    />
  </div>

  <div class="relative w-full mx-auto h-full">
    <div
      class="absolute sm:top-1/2 top-1/3 space-y-8 left-1/2 -translate-y-1/2 -translate-x-1/2 mx-auto text-center w-full"
    >
      <p class="text-xl md:text-2xl font-bold text-white">THE WEDDING OF</p>
      <p
        class="text-4xl md:text-6xl scale-150 font-bold font-bonheur-royale text-amber-600"
      >
        Serly & Rizki
      </p>
      <p class="text-md md:text-lg font-bold text-white">SABTU, 6 JUNI 2026</p>
    </div>
  </div>
  <slot />
</section>
